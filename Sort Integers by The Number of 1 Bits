You are given an integer array arr.
Sort the integers in the array in ascending order by the number of 1's in their binary representation and in case of two or more integers have the same number of 1's you have to sort them in ascending order.

Return the array after sorting it. 

/**
 * @param {number[]} arr
 * @return {number[]}
 */
var sortByBits = function(arr) {
    return arr.sort((a, b) => {
        const countBits = n => n.toString(2).split('').filter(bit => bit === '1').length;
        
        const bitsA = countBits(a);
        const bitsB = countBits(b);
        
        // If same number of 1's, sort by value ascending
        if (bitsA === bitsB) return a - b;
        
        // Otherwise sort by number of 1's ascending
        return bitsA - bitsB;
    });
};
